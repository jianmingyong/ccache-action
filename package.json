{
  "name": "ccache-action",
  "description": "GitHub Actions for ccache",
  "version": "1.4.0",
  "author": "Yong Jian Ming",
  "type": "module",
  "private": true,
  "homepage": "https://github.com/jianmingyong/ccache-action",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jianmingyong/ccache-action.git"
  },
  "bugs": {
    "url": "https://github.com/jianmingyong/ccache-action/issues"
  },
  "keywords": [
    "ccache"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": "^24"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "ci-test": "cross-env NODE_OPTIONS='--experimental-vm-modules' npx jest",
    "coverage": "npx make-coverage-badge --output-path ./badges/coverage.svg",
    "format:write": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npx eslint .",
    "lint:config": "npx eslint --inspect-config",
    "local-action": "npx @github/local-action . src/index.ts .env",
    "package": "npx rollup --config rollup.config.js",
    "package:watch": "npm run package -- --watch",
    "test": "cross-env NODE_OPTIONS='--experimental-vm-modules' npx jest",
    "all": "npm run format:write && npm run lint && npm run test && npm run coverage && npm run package"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/cache": "^6.0.0",
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@actions/glob": "^0.6.1",
    "@actions/io": "^3.0.2",
    "@actions/tool-cache": "^4.0.0",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@eslint/config-inspector": "^1.5.0",
    "@eslint/js": "^10.0.1",
    "@github/local-action": "^7.0.1",
    "@jest/globals": "^30.2.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@tsconfig/node24": "^24.0.4",
    "@tsconfig/recommended": "^1.0.13",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/semver": "^7.7.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.0",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "make-coverage-badge": "^1.2.0",
    "prettier": "^3.8.1",
    "prettier-eslint": "^16.4.2",
    "rollup": "^4.60.0",
    "ts-jest": "^29.4.6",
    "ts-jest-resolver": "^2.0.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2"
  }
}
