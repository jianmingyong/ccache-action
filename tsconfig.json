{
  "$schema": "https://json.schemastore.org/tsconfig",

  "extends": [
    "@tsconfig/recommended/tsconfig.json",
    "@tsconfig/node24/tsconfig.json"
  ],

  "compilerOptions": {
    "isolatedModules": true,
    "newLine": "lf",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noImplicitAny": true,
    "outDir": "./dist"
  },

  "include": ["src"],
  "exclude": ["__tests__", "coverage", "dist", "node_modules"]
}
